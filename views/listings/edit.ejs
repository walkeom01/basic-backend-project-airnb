<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        body {
            background: #110a4a;
        }

        h3 {
            color: aqua;
        }
    </style>
</head>

<body>
    <h3>edit listing</h3>
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT" >
        <input name="listing[title]" value="<%=listing.title%>" type="text">
        <br>
        <textarea name="listing[description]" value="<%=listing.description%>" type="text"></textarea>
        <br>
        <input name="listing[image]" value="<%=listing.image%>" type="text">
        <br>
        <input name="listing[price]" value="<%=listing.price%>" type="number">
        <br>
        <input name="listing[location]" value="<%=listing.text%>" type="text">
        <br>
        <input name="listing[country]" value="<%=listing.country%>" type="text">
        <button>edit</button>
    </form>
</body>

</html>
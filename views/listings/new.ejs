<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        body {
            background: #110a4a;
        }

        h3 {
            color: aqua;
        }
    </style>
</head>

<body>
    <h3>create a new listing</h3>
    <form method="POST" action="/listings">
        <input name="listing[title]" placeholder="enter title" type="text">
        <br>
        <textarea name="listing[description]" placeholder="description" type="text"></textarea>
        <br>
        <input name="listing[image]" placeholder="enter image url" type="text">
        <br>
        <input name="listing[price]" placeholder="enter price" type="number">
        <br>
        <input name="listing[location]" placeholder="enter location not country" type="text">
        <br>
        <input name="listing[country]" placeholder="enter   country" type="text">
        <button>add</button>
    </form>
</body>

</html>